# SINGLE SOURCE OF TRUTH FOR SENSITIVE VALUES
# Copy this file to .secrets/jarvis.env (or /home/jarvis/.secrets/jarvis.env)
# and fill each variable with your local values.
# Format: KEY=value (without quotes unless needed).

# Transport: stdio or http
STARTER_TRANSPORT=
# HTTP port used when STARTER_TRANSPORT=http
PORT=
# Timezone, example: Europe/Brussels
TZ=

# Target URL/path for npm proxy manager API (example: http://host:81/api)
NPM_URL=
# Login/identity (username or email)
NPM_IDENTITY=
# Password or API token/secret
NPM_SECRET=
