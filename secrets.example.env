# FICHIER UNIQUE DES INFORMATIONS SENSIBLES (EXEMPLE FICTIF)
# Remplace chaque valeur par les tiennes avant usage en production.
# Format obligatoire: CLE=valeur (une ligne par variable)

# Mode de transport: stdio ou http
STARTER_TRANSPORT=http
# Port HTTP de l'application
PORT=7010
# Fuseau horaire du service
TZ=Europe/Brussels

# URL/chemin de l'API cible (faux exemple)
NPM_URL=http://192.168.12.250:81/api
# Login (identifiant utilisateur fictif)
NPM_IDENTITY=lolo_lg@yahoo.fr
# Mot de passe ou token API (valeur fictive)
NPM_SECRET=Server76
