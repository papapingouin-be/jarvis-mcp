# SENSITIVE ENV EXAMPLE ONLY - DO NOT COMMIT REAL VALUES
# Copy to .secrets/jarvis.env (or your secure secret store)

# jarvis_git_bridge sensitive settings
DATABASE_URL=postgresql://jarvis:change-me@postgres:5432/jarvis
MASTER_KEY_FILE=/run/secrets/jarvis_master_key
# Optional fallback if MASTER_KEY_FILE is not available (base64-encoded 32-byte key)
MASTER_KEY=

# Legacy jarvis_npm tool credentials (legacy compatibility)
NPM_URL=http://192.168.12.250:81/api
NPM_IDENTITY=replace-me
NPM_SECRET=replace-me
