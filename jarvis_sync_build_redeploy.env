# Jarvis sync/build/redeploy workflow
# Complete the placeholders below before running the script.

# Local repo used by sync/install/build/deploy phases
JARVIS_LOCAL_REPO=C:/Users/defoy/Documents/GitHub/jarvis-mcp
JARVIS_BRANCH=main

# Optional custom commands
NPM_INSTALL_CMD="npm ci"
NPM_BUILD_CMD="npm run build"
NPM_FALLBACK_INSTALL_CMD="npm install"
NPM_ALLOW_FALLBACK_INSTALL=0
STOP_ON_LOCK_MISMATCH=1

# GitHub / Gitea
jarvis_tools_GITHUB_TOKEN=
jarvis_tools_GITEA_TOKEN=
GITHUB_REMOTE_NAME=github-src
GITHUB_REPO_URL=https://${jarvis_tools_GITHUB_TOKEN}@github.com/papapingouin-be/jarvis-mcp.git
GITEA_REPO_URL=https://${jarvis_tools_GITEA_TOKEN}@webgit.jarvis.papapingouinbe.duckdns.org/jarvisadmin/jarvis-mcp-tools.git
JARVIS_MIRROR_SCRIPT=

# Web deploy
WEB_CODE_LOCAL_SUBDIR=jarvis-config-web
WEB_REMOTE_PATH=/opt/jarvis/config-web
WEB_REMOTE_DELETE=1

# Runtime scripts deploy
SCRIPT_SOURCE_LOCAL_SUBDIR=tools/scripts
SCRIPT_REMOTE_PATH=/opt/jarvis/shared/scripts
SCRIPT_REMOTE_DELETE=1
SCRIPT_DIR_MODE=755
SCRIPT_FILE_MODE=644

# Remote target
JARVIS_srv_SSH=
JARVIS_srv_USER=

# Choose one SSH auth method:
# 1) Password auth via sshpass
JARVIS_srv_PSWD=
# 2) Key file auth
JARVIS_SSH_KEY_PATH=

# Restart / webhook
RESTART_STRATEGY=docker
PORTAINER_USE_STACK_WEBHOOK=1
JARVIS_TOOLS_WEBHOOK_URL=
jarvis_tools_PORTAINER_URL=192.168.11.206:9443
jarvis_tools_PORTAINER_USER=
jarvis_tools_PORTAINER_PASSWORD=
PORTAINER_ENDPOINT_ID=3
JARVIS_TOOLS_STACK_NAME=jarvis-tools
JARVIS_TOOLS_CONTAINER_NAME=mcp-server-starter
PORTAINER_REDEPLOY_WAIT_SECONDS=90
PORTAINER_API_FALLBACK_TO_REMOTE_COMPOSE=1
JARVIS_TOOLS_REMOTE_COMPOSE_FILE=/opt/jarvis/repos/jarvis-mcp-tools/deploy/compose.yml
JARVIS_TOOLS_REMOTE_ENV_FILE=/opt/jarvis/mcp/jarvis_sync_build_redeploy.env
JARVIS_TOOLS_REMOTE_PROJECT_NAME=jarvis-tools
JARVIS_MCPO_CONTAINER_NAME=jarvis_mcpo
USE_SUDO=1
