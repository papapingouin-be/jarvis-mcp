# Jarvis Tools env format (canonical for this project)

# Core MCP
jarvis_tools_STARTER_TRANSPORT=http
jarvis_tools_PORT=7010
jarvis_tools_CORS_ORIGIN=*
jarvis_tools_TZ=Europe/Brussels

# PostgreSQL for jarvis_git_bridge (choose one method)
# Method A: full URL
jarvis_tools_DATABASE_URL=
# Method B: split fields
jarvis_tools_PG_URL=192.168.11.206:5432
jarvis_tools_PG_DB=jarvis_memory
jarvis_tools_PG_USER=n8n
jarvis_tools_PG_PASSWORD=replace-me

# Master key for secret encryption (prefer file)
jarvis_tools_MASTER_KEY_FILE=/run/secrets/jarvis_master_key
jarvis_tools_MASTER_KEY=
jarvis_tools_GIT_BRIDGE_PG_MODULE=pg

# Legacy jarvis_npm tool
jarvis_tools_NPM_URL=http://192.168.12.250:81/api
jarvis_tools_NPM_IDENTITY=replace-me
jarvis_tools_NPM_SECRET=replace-me
jarvis_tools_NPM_BASE_DOMAIN=jarvis.example.duckdns.org
jarvis_tools_NPM_DUCKDNS_TOKEN=replace-me
jarvis_tools_NPM_DUCKDNS_DOMAIN=replace-me

# Optional infra vars (kept for workflows/scripts)
jarvis_tools_SERVER_URL=192.168.11.206
jarvis_tools_SERVER_USER=jarvis
jarvis_tools_SERVER_PASSWORD=replace-me
jarvis_tools_PORTAINER_URL=192.168.11.206:9443
jarvis_tools_PORTAINER_USER=jarvisadmin
jarvis_tools_PORTAINER_PASSWORD=replace-me

# Legacy git vars (avoid token in URL, keep only if required by external scripts)
jarvis_tools_GITEA_TOKEN=replace-me
jarvis_tools_GITEA_IDENTITY=replace-me
jarvis_tools_GITEA_URL=https://webgit.example.local/jarvisadmin/jarvis-mcp-tools.git
jarvis_tools_GITEA_SSH_HOST=192.168.11.206
jarvis_tools_GITEA_SSH_PORT=2222
jarvis_tools_GITHUB_TOKEN=replace-me
jarvis_tools_GITHUB_IDENTITY=replace-me
jarvis_tools_GITHUB_URL=https://github.com/org/repo.git

# Shared runtime scripts directory used by MCP and the web UI
jarvis_tools_SCRIPTS_HOST_PATH=/opt/jarvis/shared/scripts
jarvis_tools_SCRIPT_RUNNER_SCRIPTS_ROOT=/opt/jarvis/shared/scripts
jarvis_tools_SCRIPTS_ROOT=/opt/jarvis/shared/scripts
jarvis_tools_SYNC_BUILD_REDEPLOY_SCRIPT=/app/tools/jarvis_sync_build_redeploy.sh

# Web UI should point to the same runtime directory inside its container
# Example:
# JARVIS_UI_SCRIPTS_ROOT=/var/www/data/scripts
