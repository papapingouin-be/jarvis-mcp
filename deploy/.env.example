# MCP core
STARTER_TRANSPORT=http
PORT=7010
CORS_ORIGIN=*
TZ=Europe/Brussels

# jarvis_git_bridge
# PostgreSQL DSN used by git bridge tools
DATABASE_URL=postgresql://jarvis:change-me@postgres:5432/jarvis

# Master key handling (prefer file path mounted outside repo)
MASTER_KEY_FILE=/run/secrets/jarvis_master_key
# Fallback only if no file can be mounted (base64 32-byte key)
MASTER_KEY=

# Optional override for PG driver module name
JARVIS_GIT_BRIDGE_PG_MODULE=pg

# Legacy jarvis_npm tool credentials (deprecated for git sync use-cases)
NPM_URL=http://192.168.12.250:81/api
NPM_IDENTITY=replace-me
NPM_SECRET=replace-me

# Notes:
# - Never commit real credentials.
# - For production, prefer a separate secrets file and/or Docker secrets.
